---
import BaseHead from '../components/BaseHead.astro';
import SubscribeModal from '../components/SubscribeModal.astro';
import { SITE_CONFIG, getAssetUrl } from '../config';
import { ClientRouter } from 'astro:transitions';

// Import CSS stylesheets so Astro bundles them
import '../styles/global.css';
import '../styles/screen.css';

interface Props {
  title?: string;
  description?: string;
  image?: string | null;
  type?: 'website' | 'article';
  articleDate?: string | Date;
  tags?: string[];
  author?: string;
  current?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  articleDate,
  tags = [],
  author,
  current,
} = Astro.props;

const currentYear = new Date().getFullYear();
const bodyClass = current === 'home' ? 'home-template' : `${current || 'page'}-template`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      articleDate={articleDate}
      tags={tags}
      author={author}
    />
    <script is:inline>
        // Theme toggle script to prevent FOUC
        (function() {
            var currentTheme = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (currentTheme === 'dark' || (!currentTheme && prefersDark)) {
                document.documentElement.classList.add('dark-mode');
                document.documentElement.classList.remove('light-mode');
            } else {
                document.documentElement.classList.add('light-mode');
                document.documentElement.classList.remove('dark-mode');
            }
        })();

        // Re-run theme check on page transitions
        document.addEventListener('astro:after-swap', function() {
            var currentTheme = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (currentTheme === 'dark' || (!currentTheme && prefersDark)) {
                document.documentElement.classList.add('dark-mode');
                document.documentElement.classList.remove('light-mode');
            } else {
                document.documentElement.classList.add('light-mode');
                document.documentElement.classList.remove('dark-mode');
            }
        });
    </script>
    <ClientRouter />
</head>
<body class={bodyClass}>
    <div class="site-wrapper">
        <!-- Main Content Slot -->
        <slot />

    <!-- Footer -->
     <footer style="background: red !important; padding: 40px !important; text-align: center !important; display: block !important; visibility: visible !important;">
        <h1 style="color: white !important; font-size: 32px !important; display: block !important; margin: 0 !important;">FOOTER TEST HERE</h1>
    </footer>
    </div>

    <!-- Subscribe Modal overlay -->
    {SITE_CONFIG.subscribers && <SubscribeModal />}
</body>
</html>
